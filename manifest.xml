<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="TaskPaneApp">

  <Id>7bd195c7-46fb-44b2-b7cf-e8992f96a055</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Contoso</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="PA Slide Deck Generator"/>
  <Description DefaultValue="PowerPoint data-driven add-in."/>

  <WebApplicationInfo>
    <Id>c8e6ef39-1958-45be-8676-534a83405843</Id>
    <Resource>api://c8e6ef39-1958-45be-8676-534a83405843</Resource>
    <Scopes>
      <Scope>Files.Read</Scope>
      <Scope>Sites.Read.All</Scope>
    </Scopes>
  </WebApplicationInfo>

  <!-- ✅ FIXED: GitHub Pages URLs -->
  <IconUrl DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://officedocs.microsoft.com"/>

  <!-- ✅ FIXED -->
  <AppDomains>
    <AppDomain>https://officialfred.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <!-- ✅ FIXED -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">

    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>

          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>

                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>

                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/assets/icon-80.png"/>
      </bt:Images>

      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://officialfred.github.io/pa-slidedeck-addin/taskpane.html"/>
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="CommandsGroup.Label" DefaultValue="PA Tools"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open Add-in"/>
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the PA Slide Deck Generator"/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
